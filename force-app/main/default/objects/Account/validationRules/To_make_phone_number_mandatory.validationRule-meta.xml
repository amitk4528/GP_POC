<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>To_make_phone_number_mandatory</fullName>
    <active>false</active>
    <description>If phone field is empty, error message should reflect</description>
    <errorConditionFormula>Isblank( Phone )</errorConditionFormula>
    <errorDisplayField>Phone</errorDisplayField>
    <errorMessage>Please enter your phone number</errorMessage>
</ValidationRule>
