<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Active_Status_YES_for_New_Account</fullName>
    <active>false</active>
    <description>Reflect Error if Active status for New Account is not &apos;YES&apos;</description>
    <errorConditionFormula>AND( ISNEW() , NOT ISPICKVAL( Active__c ,&apos;YES&apos; ))</errorConditionFormula>
    <errorDisplayField>Active__c</errorDisplayField>
    <errorMessage>Please Put Active status &apos;YES&apos;</errorMessage>
</ValidationRule>
